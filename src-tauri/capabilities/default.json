{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "local": true,
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:allow-execute",
    "shell:allow-open",
    "fs:allow-read-text-file",
    "fs:allow-write-text-file",
    "fs:allow-app-write",
    "fs:allow-app-read",
    "fs:create-app-specific-dirs",
    "fs:scope-appdata-recursive",
    "dialog:allow-open"
  ]
}
