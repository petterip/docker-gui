{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "docker-gui",
  "version": "0.1.0",
  "identifier": "io.github.docker-gui",
  "build": {
    "beforeDevCommand": "pnpm start",
    "devUrl": "http://localhost:4200",
    "beforeBuildCommand": "pnpm build && pnpm run build:helper",
    "frontendDist": "../dist/docker-gui-frontend/browser"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "docker-gui",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "bin"
    ],
    "icon": [
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png",
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png"
    ]
  }
}
